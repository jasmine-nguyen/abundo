# Copy to .env.local for local dev (git-ignored). For deploys, set these in the
# build/export environment BEFORE `expo export` — EXPO_PUBLIC_* vars are inlined
# into the app bundle at export time.

# --- Cognito login (WHIT-160/162) ---------------------------------------------
# As of WHIT-162 these are REQUIRED: the app authenticates every API call with the
# Cognito ID token (the old static EXPO_PUBLIC_API_TOKEN is retired), and login is
# mandatory. A build missing these can never obtain a token → every request 403s.
# Values come from the WHIT-97 terraform outputs:
#   cognito_hosted_ui_domain -> EXPO_PUBLIC_COGNITO_HOSTED_UI_DOMAIN
#   cognito_app_client_id    -> EXPO_PUBLIC_COGNITO_APP_CLIENT_ID
#   cognito_user_pool_id     -> EXPO_PUBLIC_COGNITO_USER_POOL_ID   (WHIT-178)
# (cognito_issuer_url is NOT needed client-side — the OAuth endpoints are derived
# from the Hosted UI domain; the issuer is only used server-side for JWT validation.)
EXPO_PUBLIC_COGNITO_HOSTED_UI_DOMAIN=
EXPO_PUBLIC_COGNITO_APP_CLIENT_ID=
# WHIT-178: the User Pool id (e.g. ap-southeast-2_xxxxx). Required for native
# email/password sign-in (Cognito SDK) and the InitiateAuth token refresh.
EXPO_PUBLIC_COGNITO_USER_POOL_ID=

# Face ID / Touch ID (WHIT-161) — default off, opt-in. Requires a physical-device
# build with the expo-secure-store config plugin and enrolled biometrics. When on:
# the Cognito refresh token is stored biometric-locked and reading it (on launch /
# resume-from-background) prompts Face ID before the app is revealed. A device with
# no biometrics stores unguarded and never locks out.
EXPO_PUBLIC_AUTH_BIOMETRIC_ENABLED=
