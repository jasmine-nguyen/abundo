# Copy to .env.local for local dev (git-ignored). For deploys, set this in the
# build/export environment BEFORE `expo export` — EXPO_PUBLIC_* vars are inlined
# into the app bundle at export time. If it's missing, the /enrichments (rules)
# API calls fail loudly (see src/api.ts apiToken()).
#
# Value = the same secret stored in SSM at /whittle/api-auth-token (the API
# Gateway authorizer checks the app's Bearer token against it).
EXPO_PUBLIC_API_TOKEN=
