# Copy to .env.local for local dev (git-ignored). For deploys, set this in the
# build/export environment BEFORE `expo export` — EXPO_PUBLIC_* vars are inlined
# into the app bundle at export time. If it's missing, the /enrichments (rules)
# API calls fail loudly (see src/api.ts apiToken()).
#
# Value = the same secret stored in SSM at /whittle/api-auth-token (the API
# Gateway authorizer checks the app's Bearer token against it).
EXPO_PUBLIC_API_TOKEN=

# --- Cognito login (WHIT-160) -------------------------------------------------
# Values come from the WHIT-97 terraform outputs:
#   cognito_hosted_ui_domain -> EXPO_PUBLIC_COGNITO_HOSTED_UI_DOMAIN
#   cognito_app_client_id    -> EXPO_PUBLIC_COGNITO_APP_CLIENT_ID
# (cognito_issuer_url is NOT needed client-side — the OAuth endpoints are derived
# from the Hosted UI domain; the issuer is only used server-side for JWT validation.)
EXPO_PUBLIC_COGNITO_HOSTED_UI_DOMAIN=
EXPO_PUBLIC_COGNITO_APP_CLIENT_ID=

# Rollout flags — BOTH default off (WHIT-160 ships dark). Leave unset until the
# route cutover (WHIT-162) and an on-device verification.
#   EXPO_PUBLIC_AUTH_USE_COGNITO=true  -> send the Cognito ID token to the API
#     instead of the static secret. Do NOT enable before WHIT-162 attaches the JWT
#     authorizer to the routes, or every request 403s.
#   EXPO_PUBLIC_AUTH_GATE_ENABLED=true -> require a session (redirect to login when
#     signed out). Off = every screen reachable, as today.
EXPO_PUBLIC_AUTH_USE_COGNITO=
EXPO_PUBLIC_AUTH_GATE_ENABLED=

# Face ID / Touch ID (WHIT-161) — default off. Requires the auth gate ON, a
# physical-device build with the expo-secure-store config plugin, and enrolled
# biometrics. When on: the Cognito refresh token is stored biometric-locked and
# reading it (on launch / resume-from-background) prompts Face ID before the app
# is revealed. A device with no biometrics stores unguarded and never locks out.
EXPO_PUBLIC_AUTH_BIOMETRIC_ENABLED=
