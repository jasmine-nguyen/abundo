# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files — ignore EVERY .env variant so a real secret can't be committed
# by accident (esp. while the repo is public); keep only the blank .env.example template.
.env
.env.*
!.env.example

# typescript
*.tsbuildinfo

app-example

# Coverage (jest + python)
coverage/
# Sharded-coverage output: the local `npm run coverage:local` merge dir and the
# per-shard/CI coverage dirs (WHIT-243).
coverage-artifacts/
coverage-logic/
coverage-screen/
__pycache__/
*.py[cod]
.coverage
.coverage.*

# Lambda build dirs — ignore everything, allowlist only true source
lambda/*
!lambda/handler.py
!lambda/up_webhook.py
!lambda/banksync.py
!lambda/merchant.py
!lambda/reprocess.py
!lambda/dedupe_cleanup.py
!lambda/age_out.py
!lambda/backfill_swipe_dates.py
!lambda/requirements.txt

lambda_api/*
!lambda_api/handler.py
!lambda_api/constants.py
!lambda_api/banksync_enrichments.py
!lambda_api/insights_ai.py

# terraform
terraform/artifacts/*
terraform/layer/
terraform/build/
terraform/*.zip
terraform/*.json
.pytest_cache/
