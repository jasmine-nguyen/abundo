# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# Python
__pycache__/
*.py[cod]
lambda/rapidfuzz*

# Lambda build dir — ignore everything, allowlist only true source
lambda/*
!lambda/handler.py
!lambda/banksync.py

# terraform
terraform/artifacts/*
terraform/layer/
terraform/*.zip
terraform/*.json
