{
  "expo": {
    "scheme": "acme",
    "icon": "./assets/whittle-logo.png",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-status-bar",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Whittle uses Face ID to unlock your account and protect your login."
        }
      ]
    ],
    "name": "Whittle",
    "slug": "whittle",
    "ios": {
      "bundleIdentifier": "com.anonymous.whittle",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "215737dd-f14c-4f8c-bd56-acfb38db9401"
      }
    },
    "android": {
      "package": "com.anonymous.whittleapp"
    },
    "owner": "ramen_broth"
  }
}
