{
  "expo": {
    "scheme": "acme",
    "icon": "./assets/abundo-icon-ios.png",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-status-bar",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Abundo uses Face ID to unlock your account and protect your login."
        }
      ]
    ],
    "name": "Abundo",
    "slug": "abundo",
    "ios": {
      "bundleIdentifier": "com.jasminenguyen.whittle",
      "icon": "./assets/abundo-icon-ios.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "215737dd-f14c-4f8c-bd56-acfb38db9401"
      }
    },
    "android": {
      "package": "com.jasminenguyen.whittle",
      "adaptiveIcon": {
        "foregroundImage": "./assets/abundo-adaptive-foreground.png",
        "backgroundColor": "#1a1b26"
      }
    },
    "owner": "ramen_broth"
  }
}
