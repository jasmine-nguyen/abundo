{
  "expo": {
    "scheme": "acme",
    "icon": "./assets/whittle-logo.png",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-status-bar",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Whittle uses Face ID to unlock your account and protect your login."
        }
      ]
    ],
    "name": "Whittle",
    "slug": "whittle-app",
    "ios": {
      "bundleIdentifier": "com.anonymous.whittle-app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "38dc6b5e-3c1c-4410-a18a-30b9a8cc57b0"
      }
    },
    "android": {
      "package": "com.anonymous.whittleapp"
    }
  }
}
